    {
      "id": "nmnycpbosz4v",
      "type": "commentNode",
      "position": {
        "x": 440,
        "y": 1240
      },
      "data": {
        "text": "Switch and pulsar have their effect in cycles of the cooldown chosen by the Model Attribute",
        "width": 200,
        "height": 80,
        "color": "#6e7e44"
      }
    },
    {
      "id": "nmnycr1nkbqu",
      "type": "commentNode",
      "position": {
        "x": 1640,
        "y": 1000
      },
      "data": {
        "text": "A wire becomes charged if there is a charged wired or pulsar producing besides, but only if no switches up, down, left, right.",
        "width": 200,
        "height": 80,
        "color": "#51582c"
      }
    },
    {
      "id": "nmnyctd69zor",
      "type": "commentNode",
      "position": {
        "x": 420,
        "y": 1340
      },
      "data": {
        "text": "Switches only update their cycle when stimulated by nearby charges, while pulses cycle following the generation clock",
        "width": 200,
        "height": 80,
        "color": "#757939"
      }
    },
