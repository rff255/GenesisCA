{
  "schemaVersion": 1,
  "properties": {
    "name": "Expanded Wireworld",
    "author": "RF. Figueiredo",
    "goal": "Explore the classic wireworld",
    "description": "Based on the classic Wireworld model (https://en.wikipedia.org/wiki/Wireworld) first proposed by Brian Silverman. To facilitate experiments, I added two new cell types: Pulsar (that produces charges), and Switch (that gates charges). Each with their own controllable latency.",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "updateMode": "synchronous",
    "asyncScheme": "random-order",
    "gridWidth": 100,
    "gridHeight": 100,
    "maxIterations": 1000,
    "tags": [
      "wireworld",
      "turing-complete",
      "classic",
      "transistor"
    ]
  },
  "attributes": [
    {
      "id": "new_attribute_mnttg1qr40k",
      "name": "Type",
      "type": "tag",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "",
      "tagOptions": [
        "Empty",
        "Wire",
        "Pulsar",
        "Switch"
      ]
    },
    {
      "id": "new_attribute_mnueohamv5d",
      "name": "Charge",
      "type": "tag",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "",
      "tagOptions": [
        "Uncharged",
        "Head Charge",
        "Tail Charge"
      ]
    },
    {
      "id": "new_attribute_mnwwwkvhrn7",
      "name": "Switch Cooldown",
      "type": "integer",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "0"
    },
    {
      "id": "new_attribute_mnxz4m7b05n",
      "name": "Switch Latency",
      "type": "integer",
      "description": "Controls how many generations of charged neighbors the switch takes before turning off once.",
      "isModelAttribute": true,
      "defaultValue": "5",
      "hasBounds": true,
      "min": 0,
      "max": 30
    },
    {
      "id": "new_attribute_mnyauazsryz",
      "name": "Pulsar Latency",
      "type": "integer",
      "description": "Controls how many generations it takes for a pulse cell to go live and trigger charges around it.",
      "isModelAttribute": true,
      "defaultValue": "5",
      "hasBounds": true,
      "min": 0,
      "max": 30
    },
    {
      "id": "new_attribute_mnyayon6gbu",
      "name": "Pulsar Cooldown",
      "type": "integer",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "0"
    }
  ],
