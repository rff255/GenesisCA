{
  "schemaVersion": 1,
  "properties": {
    "name": "Wireworld (expanded)",
    "author": "Brian Silverman",
    "description": "Based on the classic Wireworld model (https://en.wikipedia.org/wiki/Wireworld). To facilitate experiments, I added two new cell types: Pulsar (that produces charges), and Switch (that gates charges). Each with their own controllable latency.",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "updateMode": "synchronous",
    "asyncScheme": "random-order",
    "gridWidth": 100,
    "gridHeight": 100,
    "maxIterations": 1000,
    "tags": [
      "wireworld",
      "turing-complete",
      "classic",
      "transistor"
    ],
    "modelAuthor": "Rodrigo F. Figueiredo",
    "thumbnail": "data:image/gif;base64,"
  },
  "attributes": [
    {
      "id": "new_attribute_mnttg1qr40k",
      "name": "Type",
      "type": "tag",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "",
      "tagOptions": [
        "Empty",
        "Wire",
        "Pulsar",
        "Switch"
      ]
    },
    {
      "id": "new_attribute_mnueohamv5d",
      "name": "Charge",
      "type": "tag",
      "description": "",
