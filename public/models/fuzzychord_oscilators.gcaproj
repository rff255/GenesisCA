{
  "schemaVersion": 1,
  "properties": {
    "name": "FuzzyChord Oscilators",
    "author": "FuzzyChord",
    "description": "Based on FuzzyChord's Golly rule studying a variant of GoL and a particular structure of oscillators that as its size increases, generally so does the its period of oscillation. His Golly rule = B45/S2345",
