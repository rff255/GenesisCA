{
  "schemaVersion": 1,
  "properties": {
    "name": "Elementary 1D CA",
    "author": "Rodrigo Figueiredo",
    "goal": "Showcase 1D Elementary CA in a 2D space",
    "description": "Demonstrating the simulation of 1D Elementary CA in a 2D space in a simple manner. Use the rule you want. By default rule 30 ( 00011110 )",
    "topology": "2d-grid",
    "boundaryTreatment": "constant",
    "gridWidth": 500,
    "gridHeight": 500,
    "maxIterations": 1000,
    "tags": [
      "1d elementary",
      "classic",
      "rule 30"
    ],
    "updateMode": "synchronous",
    "asyncScheme": "random-order"
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_4",
      "name": "Random Paint Probability",
      "type": "float",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "0.5"
    },
    {
      "id": "new_attribute_mo1ib4j3gdv",
      "name": "Solved",
      "type": "bool",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_mo1icrgjcd0",
      "name": "Case 111",
      "type": "bool",
      "description": "should case where left, current, and right are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_mo1ie7giaxt",
      "name": "Case 110",
      "type": "bool",
      "description": "should case where left, and current are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_mo1iedl3wwy",
      "name": "Case 101",
      "type": "bool",
      "description": "should case where left, and right are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_mo1iefwem9s",
      "name": "Case 100",
      "type": "bool",
      "description": "should case where left only are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "true"
    },
    {
      "id": "new_attribute_mo1ieh4xnqw",
      "name": "Case 011",
      "type": "bool",
      "description": "should case where current, and right are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "true"
    },
    {
      "id": "new_attribute_mo1iei9di1o",
      "name": "Case 010",
      "type": "bool",
      "description": "should case where only current is alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "true"
    },
    {
      "id": "new_attribute_mo1iekha1io",
      "name": "Case 001",
      "type": "bool",
      "description": "should case where only right are alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "true"
    },
    {
      "id": "new_attribute_mo1if9vff5b",
      "name": "Case 000",
      "type": "bool",
      "description": "should case where no one is alive result in alive or dead?",
      "isModelAttribute": true,
      "defaultValue": "false"
    }
  ],
  "neighborhoods": [
    {
      "id": "moore",
      "name": "1D Elementary CA Case",
      "description": "Simulating a 1D CA evolving by checking the previous row",
      "coords": [
        [
          -1,
          -1
        ],
        [
          -1,
          0
        ],
        [
          -1,
          1
        ]
      ],
      "margin": 2,
      "tags": {
        "0": "Left",
        "1": "Current",
        "2": "Right"
      }
    }
  ],
