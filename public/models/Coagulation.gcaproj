{
  "schemaVersion": 1,
  "properties": {
    "name": "Coagulation",
    "author": "Castiel & Rodrigo F. Figueiredo",
    "description": "Similar scaffolding to that of Game of Life, in which cells are alive or dead, but with different neighborhood and different under-overpopulation constants.",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "gridWidth": 300,
    "gridHeight": 300,
    "maxIterations": 1000,
    "tags": [
      "2-state",
      "experimental",
      "customizable params",
      "alternative neighborhoods",
      "outer totalistic"
    ],
    "updateMode": "synchronous",
    "asyncScheme": "random-order",
    "modelAuthor": "Rodrigo F. Figueiredo",
    "thumbnail": "data:image/gif;base64,"
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_4",
      "name": "Random Paint Probability",
      "type": "float",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "0.5"
    },
    {
      "id": "new_attribute_mnozhyq88pn",
      "name": "Underpopulation",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "1"
    },
    {
      "id": "new_attribute_mnoziofuzy9",
      "name": "Overpopulation",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "2"
    },
    {
      "id": "new_attribute_mnoziwjnoef",
      "name": "Born Constant",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "2"
    },
    {
      "id": "new_attribute_mnozjf6a2ld",
      "name": "Pattern Threshold",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "13"
    },
    {
      "id": "new_attribute_mnozx9w25wi",
      "name": "Stability",
      "type": "bool",
      "description": "Indicates if the cell has changed its 'alive' value",
      "isModelAttribute": false,
      "defaultValue": "false"
    }
  ],
  "neighborhoods": [
    {
      "id": "moore",
      "name": "Coagulation Neighborhood",
      "description": "Sparse 12 cells of Von Neumann neighborhood + 8 neighbors at radius 3",
      "coords": [[-1,0], [0,-1], [0,1], [1,0], [-3,-1], [-3,1], [-1,3], [1,3], [1,-3], [-1,-3], [3,-1], [3,1]],
      "margin": 3
    },
    {
      "id": "new_neighborhood_mnozpfe0xnf",
      "name": "Vertical Pattern",
      "description": "",
      "coords": [[-2,0], [-1,0], [1,0], [2,0], [-2,2], [-1,2], [0,2], [1,2], [2,2], [-2,-2], [-1,-2], [0,-2], [2,-2], [1,-2]],
      "margin": 2
    },
    {
      "id": "new_neighborhood_mnozq335pox",
      "name": "Horizontal Pattern",
      "description": "",
      "coords": [[0,-2], [0,-1], [0,1], [0,2], [-2,2], [-2,1], [-2,0], [-2,-1], [-2,-2], [2,-2], [2,-1], [2,0], [2,1], [2,2]],
      "margin": 2
    }
  ],
