{
  "schemaVersion": 1,
  "properties": {
    "name": "Coagulation",
    "author": "Figueiredo & Castiel",
    "goal": "Experiment with simulation of systems that fight entropy to create a more stable state.",
    "description": "Similar scaffolding to that of Game of Life, in which cells are alive or dead, but with different neighborhood and different under-overpopulation constants.",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "gridWidth": 300,
    "gridHeight": 300,
    "maxIterations": 1000,
    "tags": [
      "2-state",
      "totalistic",
      "experimental",
      "customizable params",
      "alternative neighborhoods"
    ]
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_4",
      "name": "Random Paint Probability",
      "type": "float",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "0.5"
    },
    {
      "id": "new_attribute_2",
      "name": "Trace",
      "type": "integer",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_mnozhyq88pn",
      "name": "Underpopulation",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "1"
    },
    {
      "id": "new_attribute_mnoziofuzy9",
      "name": "Overpopulation",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "2"
    },
    {
      "id": "new_attribute_mnoziwjnoef",
      "name": "Born Constant",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "2"
    },
    {
      "id": "new_attribute_mnozjf6a2ld",
      "name": "Pattern Threshold",
      "type": "integer",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "13"
    },
    {
      "id": "new_attribute_mnozx9w25wi",
      "name": "Stability",
      "type": "bool",
      "description": "Indicates if the cell has changed its 'alive' value",
      "isModelAttribute": false,
      "defaultValue": "false"
    }
  ],
