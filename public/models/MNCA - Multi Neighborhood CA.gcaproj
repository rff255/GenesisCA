{
  "schemaVersion": 1,
  "properties": {
    "name": "MNCA",
    "author": "Slackermanz",
    "goal": "",
    "description": "Multiple Neighborhoods Cellular Automata\n\nhttps://softologyblog.wordpress.com/2018/03/09/multiple-neighborhoods-cellular-automata/",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "gridWidth": 200,
    "gridHeight": 200,
    "maxIterations": 1000,
    "tags": [
      "2-state",
      "outer totalistic"
    ],
    "updateMode": "synchronous",
    "asyncScheme": "random-order",
    "useWasm": true
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_4",
      "name": "Random Brush Probability",
      "type": "float",
      "description": "Determines the chance of a cell inside the brush area to be set alive",
      "isModelAttribute": true,
      "defaultValue": "0.6",
      "hasBounds": true,
      "min": 0,
      "max": 1
    },
    {
      "id": "new_attribute_2",
      "name": "Decoration (for display only)",
      "type": "integer",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "0"
    },
    {
      "id": "new_attribute_mo5rb4mmwo8",
      "name": "Sum0 Min Death",
      "type": "integer",
      "description": "If sum_0 is between 0 and 17 then the cell dies.",
      "isModelAttribute": true,
      "defaultValue": "0",
      "hasBounds": true,
      "min": 0,
      "max": 224
    },
    {
      "id": "new_attribute_mo5rdaxlbs9",
      "name": "Sum0 Max Death",
      "type": "integer",
      "description": "If sum_0 is between 0 and 17 then the cell dies.",
      "isModelAttribute": true,
      "defaultValue": "17",
      "hasBounds": true,
      "min": 0,
      "max": 224
    },
    {
      "id": "new_attribute_mo5rdxhg22w",
      "name": "Sum0 Min Life",
      "type": "integer",
      "description": "If sum_0 is between 40 and 42 then the cell lives.",
      "isModelAttribute": true,
      "defaultValue": "40",
      "hasBounds": true,
      "min": 0,
      "max": 224
    },
