{
  "schemaVersion": 1,
  "properties": {
    "name": "MNCA",
    "author": "Slackermanz",
    "description": "Multiple Neighborhoods Cellular Automata\n\nhttps://softologyblog.wordpress.com/2018/03/09/multiple-neighborhoods-cellular-automata/",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "gridWidth": 200,
    "gridHeight": 200,
    "maxIterations": 1000,
    "tags": [
      "2-state",
      "outer totalistic"
    ],
    "updateMode": "synchronous",
    "asyncScheme": "random-order",
    "useWasm": true,
    "modelAuthor": "Rodrigo F. Figueiredo",
    "thumbnail": "data:image/gif;base64,"
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_2",
      "name": "Decoration Trace (for display only)",
