{
  "schemaVersion": 1,
  "properties": {
    "name": "Game of Life",
    "author": "John Conway",
    "goal": "Classic cellular automaton demonstrating emergent behavior",
    "description": "A zero-player game where evolution is determined by the initial state. Each cell is either alive or dead, and its next state depends on the number of alive neighbors.",
    "topology": "2d-grid",
    "boundaryTreatment": "torus",
    "gridWidth": 500,
    "gridHeight": 200,
    "maxIterations": 1000,
    "tags": [
      "classic",
      "2-state",
      "totalistic"
    ]
  },
  "attributes": [
    {
      "id": "alive",
      "name": "alive",
      "type": "bool",
      "description": "Whether the cell is alive or dead",
      "isModelAttribute": false,
      "defaultValue": "false"
    },
    {
      "id": "new_attribute_4",
      "name": "Random Paint Probability",
      "type": "float",
      "description": "",
      "isModelAttribute": true,
      "defaultValue": "0.5"
    },
    {
      "id": "new_attribute_2",
      "name": "Trace",
      "type": "integer",
      "description": "",
      "isModelAttribute": false,
      "defaultValue": "false"
    }
  ],
  "neighborhoods": [
    {
      "id": "moore",
      "name": "Moore",
      "description": "All 8 surrounding cells",
      "coords": [
        [
          -1,
          -1
        ],
        [
          -1,
          0
        ],
        [
          -1,
          1
        ],
