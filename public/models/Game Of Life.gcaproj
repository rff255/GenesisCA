{
  "schemaVersion": 1,
  "properties": {
    "name": "Game of Life",
    "author": "John Conway",
    "description": "A zero-player game where evolution is determined by the initial state. Each cell is either alive or dead, and its next state depends on the number of alive neighbors.",
