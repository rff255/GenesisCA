      "redDescription": "",
      "greenDescription": "",
      "blueDescription": ""
    },
    {
      "id": "new_mapping_6",
      "name": "Trace",
      "description": "Displays the cells alive as white dots on a black background, and when a cell dies, it leaves a purple trace that slowly decays.",
      "isAttributeToColor": true,
      "redDescription": "",
      "greenDescription": "",
      "blueDescription": ""
    }
  ],
