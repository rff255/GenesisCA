        ],
        [
          1,
          1
        ]
      ]
    }
  ],
  "mappings": [
    {
      "id": "paint",
      "name": "SetAlive",
      "description": "Allows painting alive cells on the grid",
      "isAttributeToColor": false,
      "redDescription": ">0",
      "greenDescription": "",
      "blueDescription": ""
    },
    {
      "id": "new_mapping_2",
      "name": "Random",
